#!/usr/bin/env bash
# sage-review-read — read review log and config for dashboard
# Usage: sage-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval $("$SCRIPT_DIR/sage-slug" 2>/dev/null)
SAGE_HOME="${SAGE_HOME:-$HOME/.sage}"
cat "$SAGE_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/sage-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
