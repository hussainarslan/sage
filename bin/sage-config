#!/usr/bin/env bash
# sage-config — read/write ~/.sage/config.yaml
#
# Usage:
#   sage-config get <key>          — read a config value
#   sage-config set <key> <value>  — write a config value
#   sage-config list               — show all config
#
# Env overrides (for testing):
#   SAGE_STATE_DIR  — override ~/.sage state directory
set -euo pipefail

STATE_DIR="${SAGE_STATE_DIR:-$HOME/.sage}"
CONFIG_FILE="$STATE_DIR/config.yaml"

case "${1:-}" in
  get)
    KEY="${2:?Usage: sage-config get <key>}"
    grep -E "^${KEY}:" "$CONFIG_FILE" 2>/dev/null | tail -1 | awk '{print $2}' | tr -d '[:space:]' || true
    ;;
  set)
    KEY="${2:?Usage: sage-config set <key> <value>}"
    VALUE="${3:?Usage: sage-config set <key> <value>}"
    mkdir -p "$STATE_DIR"
    if grep -qE "^${KEY}:" "$CONFIG_FILE" 2>/dev/null; then
      sed -i '' "s/^${KEY}:.*/${KEY}: ${VALUE}/" "$CONFIG_FILE"
    else
      echo "${KEY}: ${VALUE}" >> "$CONFIG_FILE"
    fi
    ;;
  list)
    cat "$CONFIG_FILE" 2>/dev/null || true
    ;;
  *)
    echo "Usage: sage-config {get|set|list} [key] [value]"
    exit 1
    ;;
esac
